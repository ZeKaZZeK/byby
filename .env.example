# Bybit API Configuration
BYBIT_API_KEY=your_testnet_api_key_here
BYBIT_API_SECRET=your_testnet_api_secret_here
BYBIT_TESTNET=true
BYBIT_BASE_URL=https://api-testnet.bybit.com

# Trading Configuration
TRADING_SYMBOL=BTC/USDT:USDT
TRADING_TIMEFRAME=1m
MAX_RISK_PER_TRADE=0.005
MAX_DAILY_LOSS=0.03
MAX_LEVERAGE=5
MAX_CONCURRENT_TRADES=3
MAX_TOTAL_EXPOSURE=0.15

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=byby
POSTGRES_USER=byby
POSTGRES_PASSWORD=byby_password
DATABASE_URL=postgresql://byby:byby_password@localhost:5432/byby

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Monitoring
PROMETHEUS_PORT=8000
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Backtest Configuration
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2025-01-01
BACKTEST_INITIAL_CAPITAL=10000

# Regime Detector
REGIME_CONFIDENCE_THRESHOLD=0.7
REGIME_HYSTERESIS_PERIODS=5
ADX_PERIOD=14
ADX_TREND_THRESHOLD=25
VOLATILITY_PERIOD=20
VOLATILITY_HIGH_THRESHOLD=0.02

# Paper Trading
PAPER_TRADING=true
PAPER_INITIAL_BALANCE=10000
